# Supabase credentials (obtener en https://supabase.com/dashboard/project/_/settings/api)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Personal Access Token (para MCP, generar en https://supabase.com/dashboard/account/tokens)
SUPABASE_ACCESS_TOKEN=sbp_your-token-here
